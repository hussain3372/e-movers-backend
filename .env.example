# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Database (Prisma)
# ---------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If the password contains @ : / ? # & % it MUST be percent-encoded.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emovers_db?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/emovers_db_test?schema=public"

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV="development"
PORT=3004
API_PREFIX="api/v1"
APP_VERSION="1.0.0"
LOG_LEVEL="info"

# Base URL of the frontend — used to build links in transactional emails.
FRONTEND_URL="http://localhost:3000"

# Comma-separated list of allowed origins.
CORS_ORIGIN="http://localhost:3000"

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET="change-me"
JWT_EXPIRES_IN="10d"
# Access-token TTL in seconds, used for the token cache.
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_EMAIL_SECRET="change-me-as-well"

# ---------------------------------------------------------------------------
# Google Sign-In
# ---------------------------------------------------------------------------
# OAuth 2.0 Web client ID from the Google Cloud console.
GOOGLE_CLIENT_ID=""

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---------------------------------------------------------------------------
# Redis (caching / sessions)
# ---------------------------------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# ---------------------------------------------------------------------------
# Mail (nodemailer)
# ---------------------------------------------------------------------------
MAIL_MAILER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USERNAME=""
# For Gmail this is an App Password, not the account password.
MAIL_PASSWORD=""
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS=""
MAIL_FROM_NAME="E House Movers"

# ---------------------------------------------------------------------------
# Admin seed account
# ---------------------------------------------------------------------------
# Used by `npm run db:seed` to bootstrap the first admin. Re-running the seed
# resets this account's password to ADMIN_PASSWORD.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# ---------------------------------------------------------------------------
# Cloudinary (file storage)
# ---------------------------------------------------------------------------
# From the Cloudinary console dashboard. All three are required — the app
# fails to start without them.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---------------------------------------------------------------------------
# Elasticsearch (log shipping)
# ---------------------------------------------------------------------------
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOST="localhost:9200"

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
